# Kopie als .env anlegen und ausfüllen – .env NICHT committen!
# Der Key ist der GEHEIME service_role- bzw. sb_secret_-Key (umgeht RLS).

SUPABASE_URL=https://tppwuvizobwnnfatysdh.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_DEIN_GEHEIMER_KEY

# Abtastintervall in Sekunden (Default 60)
POLL_SECONDS=60

# Optional: Logger-Hosts überschreiben (Defaults im Code)
# LOGGER_VOLL_HOST=192.168.100.22
# LOGGER_EIGEN_HOST=192.168.100.12

# Optional: Zähler-kWh-Stände (bezogene/eingespeiste Energie) mitspeichern.
# Register-Adressen je nach Zählermodell – erst gegen die WebUI prüfen!
# (Zum Finden des richtigen Registers: METER_SCAN nutzen, siehe unten.)
# METER_IMPORT_REG=
# METER_EXPORT_REG=
# METER_ENERGY_TYPE=u32        # u32 | i32 | u64
# METER_ENERGY_GAIN=100        # Teiler -> kWh

# Diagnose: Registerbereich des Zählers ausgeben, um die kWh-Register zu finden.
# Format start:anzahl – danach wieder leeren/auskommentieren.
# METER_SCAN=32278:40
